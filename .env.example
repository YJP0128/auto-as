# auto-as 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만들고 실제 키를 채우세요:
#   cp .env.example .env
# .env 는 .gitignore 로 커밋되지 않습니다. 이 .env.example 만 커밋됩니다.

# ── OpenAI (필수) ──────────────────────────────────────────────
# 두 곳에서 같은 키를 사용합니다:
#   1) taskmaster-ai (.taskmaster/config.json 의 provider=openai)
#   2) auto_as 패널 OpenAI 모드 (panel.py, 키가 있을 때만 켜지고 실패 시 로컬 폴백)
OPENAI_API_KEY=sk-your-key-here

# ── auto_as 패널 모델 (선택) ───────────────────────────────────
# 사용 가능 모델: gpt-5.6-sol / gpt-5.6-terra / gpt-5.6-luna
# 미설정 시 panel.py 기본값(gpt-5.6-luna) 사용
OPENAI_MODEL=gpt-5.6-terra
# 추론 강도: low | medium | high (미설정 시 medium)
OPENAI_REASONING_EFFORT=medium

# ── taskmaster research 역할 (선택) ────────────────────────────
# research=true 로 돌릴 때만 필요. 기본 흐름에서는 불필요.
# PERPLEXITY_API_KEY=pplx-your-key-here
